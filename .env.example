# ─── Required ───────────────────────────────────────────────────────────────

# Supabase (public)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service-role key (server-only). Used by the Stripe webhook and
# email_log writes. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenRouter (server-only). One key, three models can be selected per call.
OPENROUTER_API_KEY=your-openrouter-key
OPENROUTER_MODEL=x-ai/grok-3-mini
OPENROUTER_MODEL_CHEAP=x-ai/grok-3-mini
OPENROUTER_MODEL_SMART=anthropic/claude-haiku-4.5

# App URL — used in OG tags, sitemap, and Stripe redirect URLs.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Optional integrations (app degrades gracefully if missing) ─────────────

# Stripe — billing + subscription portal + webhooks
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# After you create products/prices in Stripe, paste the price IDs into
# the public.plans table (stripe_monthly_price_id / stripe_yearly_price_id).

# Resend — transactional email (welcome, billing, CV-ready)
RESEND_API_KEY=re_...
RESEND_FROM="Adam Careers <hello@adamcareers.com>"

# Composio — LinkedIn profile import
COMPOSIO_API_KEY=your-composio-api-key

# RapidAPI — reserved for future job-search integration
RAPIDAPI_KEY=
